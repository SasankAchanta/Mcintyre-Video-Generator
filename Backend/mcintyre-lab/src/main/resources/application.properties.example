# Database
spring.datasource.url=your-db-url
spring.datasource.username=your-username
spring.datasource.password=your-password

# JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# JWT
jwt.secret=your-secret-here
jwt.expiration=86400000

# Server
server.port=8080

# Spring Mail Configuration (Brevo SMTP)
spring.mail.host=smtp-relay.brevo.com
spring.mail.port=465
spring.mail.username=YOUR_BREVO_ACCOUNT_EMAIL
spring.mail.password=YOUR_BREVO_SMTP_MASTER_KEY

# Security & Authentication settings required by Brevo
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true

# Connection timeouts for stability
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=5000
spring.mail.properties.mail.smtp.writetimeout=5000